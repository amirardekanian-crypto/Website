  "cycles": [
    {
      "num": 1,
      "name": "Rebuild & Reset",
      "tagline": "Re-load What You've Lost",
      "weeks": "Weeks 1–5",
      "focuses": [
        "Progressively re-load the injured right lat and rotator cuff while correcting left-right asymmetry.",
        "Establish baseline hypertrophy and movement quality across all major patterns."
      ],
      "message": {
        "paragraphs": [
          "This cycle is about rebuilding the shoulder you need for the next decade of tennis — not the next tournament. Every rotator cuff set, every left-side lead, every controlled tempo rep is laying tissue down where you've been losing it.",
          "Mentally: your job here is patience and precision, not intensity. By the end of week 5, serving should feel smoother and more stable, the left side should be catching up to the right, and you'll hold quality deeper into practice sessions. You're not chasing numbers this cycle — you're earning the right to chase them in the next one."
        ],
        "outcomes": [
          "Pain-free serving at moderate intensity",
          "Visible reduction in left-right strength asymmetry",
          "2–3kg of added lean mass",
          "Improved shoulder girdle stability under load",
          "Sustained quality across longer practice sessions"
        ]
      }
    },
    {
      "num": 2,
      "name": "Symmetry Engine",
      "weeks": "Weeks 6–10",
      "focuses": [
        "Drive unilateral hypertrophy to close the strength and size gap between sides.",
        "Reintroduce graded overhead loading as shoulder tolerance returns."
      ],
      "teaser": {
        "subtitle": "You've rebuilt the foundation. Now we close the gap.",
        "paragraphs": [
          "Cycle 2 is where the rebuild turns into something you can actually feel on the court. The left side stops being a weak link. The shoulder stops being a liability. Overhead work comes back — carefully, on your terms.",
          "This is the cycle where your body starts to move like a semi-pro's body should. Earn it here first."
        ]
      }
    },
    {
      "num": 3,
      "name": "Armour Build",
      "weeks": "Weeks 11–15",
      "focuses": [
        "Accumulate maximum lean mass through intensified hypertrophy across the whole body.",
        "Build shoulder girdle durability with loaded carries, heavy rows, and controlled overhead work."
      ]
    },
    {
      "num": 4,
      "name": "Power Translation",
      "weeks": "Weeks 16–20",
      "focuses": [
        "Convert new muscle into tennis-specific rotational power and serve-chain speed.",
        "Maintain strength while introducing medicine ball, plyometric, and landmine rotational work."
      ]
    },
    {
      "num": 5,
      "name": "Match Engine",
      "weeks": "Weeks 21–25",
      "focuses": [
        "Build repeat-effort capacity so performance quality holds through long matches and tournament weeks.",
        "Preserve the strength and mass gained while tapering into competition-ready form."
      ]
    }
  ],
