          }
        },
        {
          "type": "simple",
          "name": "Side-to-Side Leg Swing",
          "videoUrl": null,
          "chips": [
            { "label": "×10 Each Side" }
          ],
          "cues": {
            "good": [
              "Face the wall, swing the leg across and away from the body",
              "Keep the torso tall and still — the leg does the moving"
            ],
            "bad": [
              "Twisting the hips to fake a bigger swing"
            ]
          }
        }
      ]
    },
